          "datasource": {
            "type": "prometheus",
            "uid": "${ds_prometheus}"
          },
          "expr": "count(deckhand_last_backup_status == 0) or vector(0)",
          "instant": true,
          "legendFormat": "Failed",
          "refId": "A"
        }
      ],
      "title": "Last Backup Failed",
      "type": "stat"
    },
