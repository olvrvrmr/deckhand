      "pluginVersion": "12.4.0",
      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "${ds_prometheus}"
          },
          "expr": "deckhand_last_backup_timestamp > 0",
          "format": "table",
          "instant": true,
          "legendFormat": "{{container}}",
          "refId": "A"
        },
        {
          "datasource": {
            "type": "prometheus",
            "uid": "${ds_prometheus}"
          },
          "expr": "time() - deckhand_last_backup_timestamp",
          "format": "table",
          "instant": true,
          "legendFormat": "{{container}}",
          "refId": "B"
        },
        {
          "datasource": {
            "type": "prometheus",
            "uid": "${ds_prometheus}"
          },
          "expr": "increase(deckhand_backup_failures_total[24h])",
          "format": "table",
          "instant": true,
          "legendFormat": "{{container}}",
          "refId": "C"
        },
        {
          "datasource": {
            "type": "prometheus",
            "uid": "${ds_prometheus}"
          },
          "editorMode": "code",
          "exemplar": false,
          "expr": "rate(deckhand_backup_duration_seconds_sum[24h]) / rate(deckhand_backup_duration_seconds_count[24h])",
          "format": "table",
          "instant": true,
          "legendFormat": "{{container}}",
          "range": false,
          "refId": "D"
        },
        {
          "datasource": {
            "type": "prometheus",
            "uid": "${ds_prometheus}"
          },
          "expr": "increase(deckhand_bytes_transferred_total[24h])",
          "format": "table",
          "instant": true,
          "legendFormat": "{{container}}",
          "refId": "E"
        },
        {
          "datasource": {
            "type": "prometheus",
            "uid": "${ds_prometheus}"
          },
          "expr": "deckhand_last_backup_status",
          "format": "table",
          "instant": true,
          "legendFormat": "{{container}}",
          "refId": "F"
        },
        {
          "datasource": {
            "type": "prometheus",
            "uid": "${ds_prometheus}"
          },
          "expr": "deckhand_backup_running",
          "format": "table",
          "instant": true,
          "legendFormat": "{{container}}",
          "refId": "G"
        },
        {
          "datasource": {
            "type": "prometheus",
            "uid": "${ds_prometheus}"
          },
          "expr": "(1 - deckhand_last_backup_status) + (2 * clamp_max((time() - deckhand_last_backup_timestamp) > bool 90000, 1))",
          "format": "table",
          "instant": true,
          "legendFormat": "{{container}}",
          "refId": "H"
        }
      ],
      "title": "Container Backup Status",
      "transformations": [
        {
          "id": "seriesToColumns",
          "options": {
            "byField": "container"
          }
        },
        {
          "id": "organize",
          "options": {
            "excludeByName": {
              "Time": true,
              "__name__": true,
              "instance": true,
              "job": true
            },
            "indexByName": {
              "Avg Duration (24h)": 7,
              "Backup Age": 5,
              "Container": 0,
              "Failures (24h)": 6,
              "Last Backup": 4,
              "Last Result": 3,
              "Running": 2,
              "Status": 1,
              "Transferred (24h)": 8
            },
            "renameByName": {
              "Value #A": "Last Backup",
              "Value #B": "Backup Age",
              "Value #C": "Failures (24h)",
              "Value #D": "Avg Duration (24h)",
              "Value #E": "Transferred (24h)",
              "Value #F": "Last Result",
              "Value #G": "Running",
              "Value #H": "Status",
              "container": "Container"
            }
          }
        }
      ],
      "type": "table"
